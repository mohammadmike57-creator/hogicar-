{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://hogicar-backend.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://hogicar-backend.onrender.com/uploads/:path*"
    },
    {
      "source": "/robots.txt",
      "destination": "https://hogicar-backend.onrender.com/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://hogicar-backend.onrender.com/sitemap.xml"
    },
    {
      "source": "/sitemap-:type.xml",
      "destination": "https://hogicar-backend.onrender.com/sitemap-:type.xml"
    },
    {
      "source": "/((?!api|static|uploads|assets|favicon|manifest|logo|service-worker).*[^\\.]*)",
      "destination": "https://hogicar-backend.onrender.com/$1"
    }
  ]
}
