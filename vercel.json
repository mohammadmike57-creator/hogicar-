{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://hogicar-backend.onrender.com/sitemap.xml" },
    { "source": "/sitemap-:path*", "destination": "https://hogicar-backend.onrender.com/sitemap-:path*" },
    { "source": "/robots.txt", "destination": "https://hogicar-backend.onrender.com/robots.txt" },
    { "source": "/api/pages/sitemap.xml", "destination": "https://hogicar-backend.onrender.com/api/pages/sitemap.xml" },
    { "source": "/api/seo/sitemap.xml", "destination": "https://hogicar-backend.onrender.com/api/seo/sitemap.xml" },
    { "source": "/api/:path*", "destination": "https://hogicar-backend.onrender.com/api/:path*" }
  ]
}
